@page "/"

<PageTitle>Currículo | Dev .NET</PageTitle>

<div class="container py-4">
    <div class="row">
        <div class="col-lg-4">
            <div class="text-center p-4 bg-light rounded-3 mb-4">
                <img src="https://i.pinimg.com/736x/41/37/c2/4137c210150d235384ebb4813bfbb322.jpg"
                     class="rounded-circle mb-3" width="120" />
                <h3>João Augusto</h3>
                <p class="text-muted">Estagiário</p>
            </div>
        </div>

        <div class="col-lg-8">
            <h2 class="mb-4">Experiência Profissional</h2>
            
            @foreach (Experiencia exp in MinhasExperiencias)
            {
                <ExoerienciaCard Dados="exp" />
            }
        </div>
    </div>
</div>

@code {
    private List<Experiencia> MinhasExperiencias = new()
    {
        new Experiencia {
            Empresa = "AS Softwares",
            Cargo = "Estagiário",
            Inicio = "2026",
            Descricao = "Atuação no desenvolvimento de programas em 3D e utilizando IA."
        },
        new Experiencia {
            Empresa = "Una",
            Cargo = "Estudante",
            Inicio = "2026",
            Fim = "2031",
            Descricao = "Estudar."
        }
    };
}